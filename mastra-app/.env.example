# TACTIX Backend Environment Variables

# 1. Google Gemini API Key (Required)
# Used for all agents (Google Gemini 2.0/3.1 models)
# Get one at: https://aistudio.google.com/
GOOGLE_API_KEY=your_google_api_key_here

# 2. Exa AI Search API Key (Required)
# Used for real-time web intelligence and news fetching
# Get one at: https://exa.ai/
EXA_API_KEY=your_exa_api_key_here

# 3. World Monitor Base URL (Optional)
# If you are running the World Monitor service separately, specify its URL here.
# Defaults to http://localhost:8080 if not set.
WORLD_MONITOR_BASE_URL=http://localhost:8080

# 4. Server Port (Optional)
# The port the Express API will listen on.
# Defaults to 3001.
PORT=3001
